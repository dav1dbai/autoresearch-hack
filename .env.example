# Folder-scoped overrides. Copy to .env and fill in. .env is gitignored.
# Loaded by python-dotenv so creds NEVER touch your global Modal/OpenAI config.

# --- Modal: hackathon-scoped profile + explicit token override. NOT the work workspace. ---
MODAL_PROFILE=autoresearch-hack
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# --- Modal: deployed app (default) — not ephemeral in Modal dashboard ---
AR2_MODAL_DEPLOYED=1
# AR2_MODAL_DEPLOYED=0   # fallback: ephemeral app.run() (use --modal-ephemeral)
# AR2_MODAL_REUSE=1      # only when AR2_MODAL_DEPLOYED=0 — one app.run() per process

# --- LLM creds (hackathon-provisioned) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Headless coding agents (Codex via Raindrop MCP → Workshop traces) ---
# Default wrapper mirrors Workshop's codex chat: raindrop workshop mcp + codex exec.
INNER_AGENT_CMD=./scripts/raindrop_codex_exec.sh exec -m gpt-5-codex -c preferred_auth_method=apikey
MUTATE_AGENT_CMD=./scripts/raindrop_codex_exec.sh exec -m gpt-5-codex -c preferred_auth_method=apikey
# AR2_CODEX_EXTRA_FLAGS=-m gpt-5-codex -c preferred_auth_method=apikey
# Bare codex (no Raindrop traces): INNER_AGENT_CMD=codex exec

# --- Raindrop Workshop (SQL mirror at obs/ar2_workshop.db; optional OTLP UI push) ---
RAINDROP_WORKSHOP=1
# RAINDROP_BIN=~/.raindrop/bin/raindrop
# Local UI + DB (always on your laptop):
#   raindrop workshop   →  http://127.0.0.1:5899
# Modal Codex → host Workshop (tunnel required):
#   ./scripts/workshop_ngrok.sh start && ./scripts/workshop_ngrok.sh sync-env
# Workshop UI shows real Codex traces only (not harness score spans).
# RAINDROP_WORKSHOP_UI_PUSH=0   # default — do not push synthetic evaluate runs to UI
# RAINDROP_WORKSHOP_URL=https://xxxx.ngrok-free.app
# RAINDROP_LOCAL_DEBUGGER=https://xxxx.ngrok-free.app/v1/

# --- Vast.ai GPU scoring (Modal agents → _vast_gpu_run → SSH to rented GPU) ---
# Host .env (for --vast-rent provisioning only):
VAST_API_KEY=
# Modal secret for _vast_gpu_run (auto-synced on --vast-rent, or manual):
#   modal secret create autoresearch-vast VAST_API_KEY=your_key --force
AR2_VAST_SECRET=autoresearch-vast
VAST_INSTANCE_ID=
VAST_GPU_NAME=RTX_4090
VAST_MAX_PRICE=0.60
MATMUL_TARGET_GFLOPS=400.0

# --- Local paths (optional overrides) ---
# AR2_CACHE_DIR=versions   # default: <repo>/versions/ for improve() snapshot dirs

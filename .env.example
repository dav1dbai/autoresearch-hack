# Folder-scoped overrides. Copy to .env and fill in. .env is gitignored.
# Loaded by python-dotenv so creds NEVER touch your global Modal/OpenAI config.

# --- Modal: hackathon-scoped profile + explicit token override. NOT the work workspace. ---
MODAL_PROFILE=autoresearch-hack
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# --- Modal: deployed app (default) — not ephemeral in Modal dashboard ---
AR2_MODAL_DEPLOYED=1
# AR2_MODAL_DEPLOYED=0   # fallback: ephemeral app.run() (use --modal-ephemeral)
# AR2_MODAL_REUSE=1      # only when AR2_MODAL_DEPLOYED=0 — one app.run() per process

# --- LLM creds (hackathon-provisioned) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Headless coding agents the loops shell out to. `codex exec` or `claude -p`. ---
INNER_AGENT_CMD=codex exec
MUTATE_AGENT_CMD=codex exec

# --- Raindrop Workshop (UI at http://localhost:5899 — OTLP ingest only) ---
RAINDROP_WORKSHOP=1
# AR² SQL mirror (default obs/ar2_workshop.db). NEVER point at ~/.raindrop/raindrop_workshop.db.
# RAINDROP_WORKSHOP_DB_PATH=obs/ar2_workshop.db
# RAINDROP_WORKSHOP_URL=http://127.0.0.1:5899

# --- Vast.ai GPU scoring (Modal agents → _vast_gpu_run → SSH to rented GPU) ---
# Host .env (for --vast-rent provisioning only):
VAST_API_KEY=
# Modal secret for _vast_gpu_run (auto-synced on --vast-rent, or manual):
#   modal secret create autoresearch-vast VAST_API_KEY=your_key --force
AR2_VAST_SECRET=autoresearch-vast
VAST_INSTANCE_ID=
VAST_GPU_NAME=RTX_4090
VAST_MAX_PRICE=0.60
MATMUL_TARGET_GFLOPS=400.0

# --- Local paths (optional overrides) ---
# AR2_CACHE_DIR=versions   # default: <repo>/versions/ for improve() snapshot dirs

# Folder-scoped overrides. Copy to .env and fill in. .env is gitignored.

# Modal — folder-scoped profile (written to ~/.modal.toml) + raw token override.
MODAL_PROFILE=autoresearch-hack
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# OpenAI / Codex (inner + mutation agents).
OPENAI_API_KEY=

# Coding agent the loops shell out to. Codex (OpenAI) by default; swap to claude if desired.
INNER_AGENT_CMD=codex exec
MUTATE_AGENT_CMD=codex exec
